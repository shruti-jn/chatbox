generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model District {
  id               String                @id @default(uuid())
  name             String
  config           Json?
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  appInstances     AppInstance[]
  auditEvents      AuditEvent[]
  classrooms       Classroom[]
  conversations    Conversation[]
  deletionRequests DataDeletionRequest[]
  catalogEntries   DistrictAppCatalog[]
  emailOutbox      EmailOutbox[]
  consents         ParentalConsent[]
  safetyEvents     SafetyEvent[]
  schools          School[]
  toolInvocations  ToolInvocation[]
  users            User[]

  @@map("districts")
}

model School {
  id         String      @id @default(uuid())
  districtId String      @map("district_id")
  name       String
  createdAt  DateTime    @default(now()) @map("created_at")
  classrooms Classroom[]
  district   District    @relation(fields: [districtId], references: [id])
  users      User[]

  @@index([districtId])
  @@map("schools")
}

model User {
  id                 String                @id @default(uuid())
  districtId         String                @map("district_id")
  schoolId           String?               @map("school_id")
  role               UserRole
  displayName        String                @map("display_name")
  externalId         String?               @unique @map("external_id")
  gradeBand          GradeBand?            @map("grade_band")
  emailHash          String?               @map("email_hash")
  consentStatus      ConsentStatus         @default(pending) @map("consent_status")
  deletionScheduledAt DateTime?            @map("deletion_scheduled_at")
  createdAt          DateTime              @default(now()) @map("created_at")
  lastLoginAt        DateTime?             @map("last_login_at")
  auditEvents        AuditEvent[]
  memberships        ClassroomMembership[]
  classroomsTeaching Classroom[]           @relation("teacher")
  conversations      Conversation[]
  whispersSent       Message[]             @relation("whisperAuthor")
  oauthTokens        OAuthToken[]
  consent            ParentalConsent?
  safetyEvents       SafetyEvent[]
  district           District              @relation(fields: [districtId], references: [id])
  school             School?               @relation(fields: [schoolId], references: [id])

  @@index([districtId, role])
  @@map("users")
}

model Classroom {
  id            String                @id @default(uuid())
  districtId    String                @map("district_id")
  schoolId      String?               @map("school_id")
  teacherId     String                @map("teacher_id")
  name          String
  joinCode      String                @unique @map("join_code")
  gradeBand     GradeBand             @map("grade_band")
  aiConfig      Json?                 @map("ai_config")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  appConfigs    ClassroomAppConfig[]
  memberships   ClassroomMembership[]
  district      District              @relation(fields: [districtId], references: [id])
  school        School?               @relation(fields: [schoolId], references: [id])
  teacher       User                  @relation("teacher", fields: [teacherId], references: [id])
  conversations Conversation[]

  @@index([teacherId])
  @@map("classrooms")
}

model ClassroomMembership {
  id          String    @id @default(uuid())
  classroomId String    @map("classroom_id")
  studentId   String    @map("student_id")
  districtId  String    @map("district_id")
  joinedAt    DateTime  @default(now()) @map("joined_at")
  classroom   Classroom @relation(fields: [classroomId], references: [id])
  student     User      @relation(fields: [studentId], references: [id])

  @@unique([classroomId, studentId])
  @@index([districtId])
  @@map("classroom_memberships")
}

model App {
  id                 String               @id @default(uuid())
  name               String
  description        String
  developerId        String?              @map("developer_id")
  toolDefinitions    Json                 @map("tool_definitions")
  uiManifest         Json                 @map("ui_manifest")
  permissions        Json
  complianceMetadata Json                 @map("compliance_metadata")
  interactionModel   InteractionModel     @default(single_user) @map("interaction_model")
  reviewStatus       AppReviewStatus      @default(pending_review) @map("review_status")
  reviewResults      Json?                @map("review_results")
  version            String
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  healthUrl          String?              @map("health_url")
  healthEvents       AppHealthEvent[]
  instances          AppInstance[]
  classroomConfigs   ClassroomAppConfig[]
  catalogEntries     DistrictAppCatalog[]
  toolInvocations    ToolInvocation[]

  @@index([reviewStatus])
  @@map("apps")
}

model DistrictAppCatalog {
  id              String        @id @default(uuid())
  districtId      String        @map("district_id")
  appId           String        @map("app_id")
  status          CatalogStatus
  approvedBy      String?       @map("approved_by")
  approvedAt      DateTime?     @map("approved_at")
  rejectionReason String?       @map("rejection_reason")
  app             App           @relation(fields: [appId], references: [id])
  district        District      @relation(fields: [districtId], references: [id])

  @@unique([districtId, appId])
  @@map("district_app_catalog")
}

model ClassroomAppConfig {
  id          String    @id @default(uuid())
  classroomId String    @map("classroom_id")
  appId       String    @map("app_id")
  districtId  String    @map("district_id")
  enabled     Boolean   @default(true)
  enabledAt   DateTime  @default(now()) @map("enabled_at")
  enabledBy   String?   @map("enabled_by")
  app         App       @relation(fields: [appId], references: [id])
  classroom   Classroom @relation(fields: [classroomId], references: [id])

  @@unique([classroomId, appId])
  @@index([districtId])
  @@map("classroom_app_configs")
}

model AppInstance {
  id             String                @id @default(uuid())
  appId          String                @map("app_id")
  conversationId String                @map("conversation_id")
  districtId     String                @map("district_id")
  status         AppInstanceStatus     @default(loading)
  stateSnapshot  Json?                 @map("state_snapshot")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  terminatedAt   DateTime?             @map("terminated_at")
  app            App                   @relation(fields: [appId], references: [id])
  conversation   Conversation          @relation(fields: [conversationId], references: [id])
  district       District              @relation(fields: [districtId], references: [id])
  collabSession  CollaborativeSession?

  @@index([conversationId, status])
  @@index([appId])
  @@map("app_instances")
}

model Conversation {
  id              String           @id @default(uuid())
  districtId      String           @map("district_id")
  classroomId     String           @map("classroom_id")
  studentId       String           @map("student_id")
  title           String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  appInstances    AppInstance[]
  classroom       Classroom        @relation(fields: [classroomId], references: [id])
  district        District         @relation(fields: [districtId], references: [id])
  student         User             @relation(fields: [studentId], references: [id])
  messages        Message[]
  toolInvocations ToolInvocation[]

  @@index([classroomId, studentId])
  @@index([districtId, updatedAt])
  @@map("conversations")
}

model Message {
  id              String       @id @default(uuid())
  conversationId  String       @map("conversation_id")
  districtId      String       @map("district_id")
  authorRole      MessageRole  @map("author_role")
  contentParts    Json         @map("content_parts")
  safetyVerdict   Json?        @map("safety_verdict")
  tokenCount      Int?         @map("token_count")
  whisperAuthorId String?      @map("whisper_author_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  conversation    Conversation @relation(fields: [conversationId], references: [id])
  whisperAuthor   User?        @relation("whisperAuthor", fields: [whisperAuthorId], references: [id])

  @@index([conversationId, createdAt])
  @@index([districtId])
  @@map("messages")
}

model CollaborativeSession {
  id               String               @id @default(uuid())
  districtId       String               @map("district_id")
  appInstanceId    String               @unique @map("app_instance_id")
  sessionCode      String               @unique @map("session_code")
  interactionModel InteractionModel     @map("interaction_model")
  status           SessionStatus        @default(active)
  createdBy        String               @map("created_by")
  createdAt        DateTime             @default(now()) @map("created_at")
  closedAt         DateTime?            @map("closed_at")
  appInstance      AppInstance          @relation(fields: [appInstanceId], references: [id])
  participants     SessionParticipant[]

  @@map("collaborative_sessions")
}

model SessionParticipant {
  id              String               @id @default(uuid())
  sessionId       String               @map("session_id")
  userId          String               @map("user_id")
  colorAssignment String?              @map("color_assignment")
  turnOrder       Int?                 @map("turn_order")
  joinedAt        DateTime             @default(now()) @map("joined_at")
  disconnectedAt  DateTime?            @map("disconnected_at")
  session         CollaborativeSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, userId])
  @@map("session_participants")
}

model OAuthToken {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  provider              String
  accessTokenEncrypted  String   @map("access_token_encrypted")
  refreshTokenEncrypted String   @map("refresh_token_encrypted")
  expiresAt             DateTime @map("expires_at")
  scopes                Json?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  user                  User     @relation(fields: [userId], references: [id])

  @@unique([userId, provider])
  @@map("oauth_tokens")
}

model ParentalConsent {
  id              String        @id @default(uuid())
  studentId       String        @unique @map("student_id")
  districtId      String        @map("district_id")
  parentEmailHash String        @map("parent_email_hash")
  consentStatus   ConsentStatus @default(pending) @map("consent_status")
  consentDate     DateTime?     @map("consent_date")
  revokedDate     DateTime?     @map("revoked_date")
  createdAt       DateTime      @default(now()) @map("created_at")
  consentToken    String?       @map("consent_token")
  tokenExpiresAt  DateTime?     @map("token_expires_at")
  district        District      @relation(fields: [districtId], references: [id])
  student         User          @relation(fields: [studentId], references: [id])

  @@index([districtId])
  @@index([consentToken])
  @@map("parental_consents")
}

model DataDeletionRequest {
  id                String         @id @default(uuid())
  studentId         String         @map("student_id")
  districtId        String         @map("district_id")
  requestedBy       String         @map("requested_by")
  reason            String?        @map("reason")
  requestedAt       DateTime       @default(now()) @map("requested_at")
  completedAt       DateTime?      @map("completed_at")
  status            DeletionStatus @default(pending)
  scheduledDeleteBy DateTime?      @map("scheduled_delete_by")
  district          District       @relation(fields: [districtId], references: [id])

  @@map("data_deletion_requests")
}

model EmailOutbox {
  id            String    @id @default(uuid())
  districtId    String    @map("district_id")
  recipientHash String    @map("recipient_hash")
  templateId    String    @map("template_id")
  payload       Json
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  district      District  @relation(fields: [districtId], references: [id])

  @@index([districtId])
  @@map("email_outbox")
}

model AuditEvent {
  id           String   @id @default(uuid())
  districtId   String   @map("district_id")
  userId       String   @map("user_id")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  district     District @relation(fields: [districtId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@index([districtId, createdAt])
  @@index([userId])
  @@index([resourceType, resourceId])
  @@map("audit_events")
}

model SafetyEvent {
  id                     String          @id @default(uuid())
  districtId             String          @map("district_id")
  userId                 String          @map("user_id")
  eventType              SafetyEventType @map("event_type")
  severity               Severity
  messageContextRedacted String?         @map("message_context_redacted")
  actionTaken            String          @map("action_taken")
  createdAt              DateTime        @default(now()) @map("created_at")
  district               District        @relation(fields: [districtId], references: [id])
  user                   User            @relation(fields: [userId], references: [id])

  @@index([districtId, createdAt])
  @@index([severity])
  @@map("safety_events")
}

model ToolInvocation {
  id             String           @id @default(uuid())
  districtId     String           @map("district_id")
  conversationId String           @map("conversation_id")
  appId          String           @map("app_id")
  toolName       String           @map("tool_name")
  parameters     Json?
  result         Json?
  status         InvocationStatus
  latencyMs      Int              @map("latency_ms")
  createdAt      DateTime         @default(now()) @map("created_at")
  app            App              @relation(fields: [appId], references: [id])
  conversation   Conversation     @relation(fields: [conversationId], references: [id])
  district       District         @relation(fields: [districtId], references: [id])

  @@index([appId, createdAt])
  @@index([conversationId])
  @@map("tool_invocations")
}

model AppHealthEvent {
  id        String   @id @default(uuid())
  appId     String   @map("app_id")
  eventType String   @map("event_type")
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")
  app       App      @relation(fields: [appId], references: [id])

  @@index([appId])
  @@map("app_health_events")
}

enum UserRole {
  student
  teacher
  district_admin
}

enum GradeBand {
  k2
  g35
  g68
  g912
}

enum InteractionModel {
  single_user
  turn_based
  concurrent
}

enum AppReviewStatus {
  pending_review
  approved
  rejected
  suspended
}

enum CatalogStatus {
  approved
  rejected
  suspended
}

enum AppInstanceStatus {
  loading
  active
  suspended
  collapsed
  terminated
  error
}

enum MessageRole {
  student
  assistant
  system
  teacher_whisper
}

enum SessionStatus {
  active
  closed
}

enum ConsentStatus {
  pending
  granted
  denied
  revoked
}

enum DeletionStatus {
  pending
  in_progress
  completed
}

enum SafetyEventType {
  pii_detected
  injection_detected
  content_blocked
  crisis_detected
  app_content_blocked
}

enum Severity {
  safe
  warning
  blocked
  critical
}

enum InvocationStatus {
  success
  error
  timeout
}
