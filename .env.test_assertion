# ChatBridge v2 Environment Variables

# Database
DATABASE_URL=postgresql://chatbridge:chatbridge_dev@localhost:5432/chatbridge

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production

# Spotify OAuth
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# OpenWeatherMap
OPENWEATHER_API_KEY=your-openweathermap-key

# Langfuse (self-hosted)
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_BASE_URL=http://localhost:3002
LANGFUSE_HOST=http://localhost:3002

# LTI 1.3
LTI_PLATFORM_ID=your-lti-platform-id
LTI_CLIENT_ID=your-lti-client-id

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGINS=http://localhost:1212,http://localhost:3000

# OAuth token encryption
OAUTH_ENCRYPTION_KEY=your-32-byte-hex-key-change-in-production
