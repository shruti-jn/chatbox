{
  "compilerOptions": {
    "incremental": true,
    "target": "es2021",
    "module": "esnext",
    "lib": ["dom", "es2023"],
    "jsx": "react-jsx",
    "strict": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@shared/*": ["./src/shared/*"],
      "@chatbridge/shared": ["./packages/shared/src/index.ts"]
    },
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "outDir": ".erb/dll",
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "tmp",
    "test",
    "release",
    "packages/backend",
    "packages/sdk",
    ".erb/dll",
    "ios",
    "android"
  ]
}
